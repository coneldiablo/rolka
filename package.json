{
  "name": "rolka",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:docker": "next dev --hostname 0.0.0.0",
    "bot:polling": "tsx src/bot/polling.ts",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "ci": "npm run lint && npm run typecheck && npm test -- --run && npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:validate": "prisma validate",
    "prisma:push": "prisma db push",
    "db:backup": "sh scripts/db-backup.sh"
  },
  "dependencies": {
    "@google/genai": "^1.34.0",
    "@prisma/client": "^6.19.0",
    "bullmq": "^5.79.2",
    "grammy": "^1.38.3",
    "lucide-react": "^0.562.0",
    "next": "^16.2.9",
    "openai": "^6.13.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.2.9",
    "prisma": "^6.19.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
